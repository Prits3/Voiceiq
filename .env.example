DATABASE_URL=postgresql://user:password@host/dbname
SECRET_KEY=your-random-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=30
CORS_ORIGINS=https://your-frontend-domain.vercel.app

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15551234567

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# Kokoro-Web (self-hosted TTS — primary voice for calls, free)
# Deploy on Railway: https://github.com/eduardolat/kokoro-web
KOKORO_BASE_URL=https://your-kokoro-app.railway.app/api/v1
KOKORO_API_KEY=your-kokoro-secret-key

# Azure Neural TTS (fallback if Kokoro is unavailable)
# Free tier: 500,000 chars/month — https://azure.microsoft.com/en-us/products/ai-services/text-to-speech
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=westeurope

# ElevenLabs (optional)
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Deepgram (optional)
DEEPGRAM_API_KEY=your-deepgram-api-key

# Public URL for Twilio webhooks (use ngrok in dev)
BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
